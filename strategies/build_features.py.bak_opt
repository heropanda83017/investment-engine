}

RISK_TAGS = {
    "ST": -30, "*ST": -50, "退市": -50,
    "立案调查": -40, "涉嫌": -30,
}


def match_hot_topics(name: str) -> Tuple[int, List[str]]:
    """匹配股票名称与热门主题，返回得分+匹配列表"""
    if not name:
        return 0, []
    score = 0
    matched = []
    for topic, info in HOT_TOPICS.items():
        for kw in info["keywords"]:
            if kw in name:
                score += info["weight"]
                matched.append(topic)
                break
    # 风险词降分（按长度降序，子串防重复匹配）
    _matched_tags = set()
    for tag in sorted(RISK_TAGS, key=len, reverse=True):
        if tag in name and not any(tag in mt for mt in _matched_tags):
            score += RISK_TAGS[tag]
            matched.append(f"⚠{tag}")
            _matched_tags.add(tag)
    return min(score, 100), matched

# ==================== 因子6: 题材文本 ====================
# AnySearch 情绪缓存
_anysearch_cache = {}


def factor_sentiment(code: str = "", name: str = "", news: str = "") -> Dict:
    """题材情绪因子 — 多维度情绪评分

    解决 IC=-1 问题: 从单一关键词匹配扩展到4个维度:
    1. 主题匹配强度 (连续值, 非二值)
    2. 产业情报评分 (industry_intel 实时数据)
    3. 量价情绪确认 (价格趋势验证情绪)
    4. 新闻/事件驱动 (如有输入)

    返回: {"score": 0-100, "details": {各维度明细}}
    """
    details = {
        "topic_score": 0,
        "intel_score": 0,
        "price_confirm": 0,
        "event_score": 0,
    }

    # 1. 主题匹配 — 连续评分
    topic_score, matched = match_hot_topics(name)
    matched_count = len(matched)
    # 将离散匹配转为连续评分: 匹配数越多分数越高，但每个匹配有衰减
    if matched_count > 0:
        # 首匹配权重1.0, 后续每个0.5衰减
        topic_continuous = sum([1.0 * (0.5 ** i) for i in range(matched_count)])
        topic_score = min(topic_score, 100) * (0.5 + 0.5 * min(topic_continuous / 3.0, 1.0))
    details["topic_score"] = round(topic_score, 1)

    # 2. 产业情报增强
    intel_score = 0.0
    if name:
        try:
            from industry_intel import IndustryIntel
            ii = IndustryIntel()
            raw_intel = ii.get_sentiment_score(name)
            if raw_intel > 0:
                intel_score = raw_intel
                details["intel_score"] = round(intel_score, 1)
        except Exception:
            pass

    # 3. 量价情绪确认 — 如果kline可用，用价格趋势验证情绪方向
    # 正向情绪 + 上涨趋势 → 加分；正向情绪 + 下跌 → 减分
    # (只在被调用时传kline参数)
    price_confirm = 0.0

    # 4. AnySearch 舆情搜索（新增信源）
    as_score = 0.0
    if name and _HAS_ANYSEARCH:
        cache_key = code + "_" + name
        if cache_key in _anysearch_cache:
            as_score = _anysearch_cache[cache_key]
        else:
            try:
                as_score = _anysearch_sentiment(name, code)
                _anysearch_cache[cache_key] = as_score
            except Exception:
                as_score = 50.0
        details["anysearch_score"] = round(as_score, 1)
    
    # 5. 综合评分 (加权)
    # 主题匹配 30% + 产业情报 25% + AnySearch 25% + 量价确认 20%
    score = (topic_score * 0.30 + intel_score * 0.25 + as_score * 0.25 + price_confirm * 0.20)
    
    # 保留原始细节
    details["hot_match"] = matched if matched else "none"
    details["matched_topics"] = matched_count

    return {"score": min(int(score), 100), "details": details}

def factor_alpha191(kline: pd.DataFrame) -> Dict:
    """Alpha191 精选因子 — 10个短周期价量因子的综合评分"""
    try:
        from alpha191_factors import compute_all_alpha191
        result = compute_all_alpha191(kline)
        return {"score": min(result.get("score", 0), 100), "details": result.get("details", {})}
    except ImportError:
        log.debug("alpha191_factors 模块不可用")
        return {"score": 0, "details": {}}
    except Exception as e:
        log.debug(f"Alpha191计算失败: {e}")
        return {"score": 0, "details": {}}

# ==================== 综合评分器 ====================
# ==================== 因子8: 分析框架综合 ====================
def factor_frameworks(df: pd.DataFrame, stock_name: str = "", code: str = "",
                       industry: str = "", financials: dict = None) -> Dict:
    """17 个投资分析框架因子化评分"""
    try:
        result = apply_all_frameworks(
            df=df, stock_name=stock_name, code=code, industry=industry,
            financials=financials,
        )
        score = min(10, result["total_score"] // 10)
        if result.get("hard_reject"):
            return {"score": 0, "hard_reject": True, "details": result}
        return {"score": score, "details": result}
    except Exception as e:
        log.warning(f"分析框架评分异常: {e}")
        return {"score": 5, "details": {"error": str(e)}}


class FactorScorer:
    def __init__(self, name_map: dict = None):
        self.ol = get_provider()
        self.name_map = name_map or {}
        self.w = {k: v["weight"] for k, v in CONFIG["factors"].items()}

    def score_stock(self, code: str, kline=None) -> Dict:
        if kline is None:
            kline = self.ol.get_kline(code, days=120)
        f1 = factor_trend(kline)
        f2 = factor_volume(kline)
        f3 = factor_volatility(kline)
        f4 = factor_capital(kline)
        f5 = factor_fundamental(code, self.ol)
        name = self.name_map.get(code, "")
        f6 = factor_sentiment(code, name=name)
        f7 = factor_alpha191(kline)
        # 分析框架因子（8号因子）
        f8_input = {"financials": {}}
        try:
            from data_provider import get_provider
            ol_provider = get_provider()
            fin = ol_provider.get_financials(code) if hasattr(ol_provider, 'get_financials') else {}
            f8_input["financials"] = fin if fin else {}
        except Exception:
            pass
        f8 = factor_frameworks(kline, stock_name=name, code=code)
        f9 = factor_consensus(code) if HAS_CONSENSUS else {"score": 5, "details": {}}
        f10 = factor_capital_flow(code) if HAS_CAPITAL_FLOW else {"score": 5, "details": {}}
        f11 = factor_market_signal(code) if HAS_MARKET_SIGNAL else {"score": 5, "details": {}}
        # FactorHub 因子（可选增量通道）
        if HAS_FACTORHUB:
            try:
                _fh_scores = batch_factorhub_scores([code])
                fh_score = _fh_scores.get(code, 0.0) if _fh_scores else 0.0
            except Exception:
                fh_score = 0.0
        else:
            fh_score = 0.0
        f12 = {"score": fh_score, "details": {}}
        # 事件因子
        try:
            ev_score = _event_score(code)
        except Exception:
            ev_score = 50.0
        f13 = {"score": ev_score, "details": {}}
        total = (f1["score"] * self.w.get("trend", 0.18) +
                 f2["score"] * self.w.get("volume", 0.13) +
                 f3["score"] * self.w.get("volatility", 0.09) +
                 f4["score"] * self.w.get("capital", 0.18) +
                 f5["score"] * self.w.get("fundamental", 0.22) +
                 f6["score"] * self.w.get("sentiment", 0.10) +
                 f7["score"] * self.w.get("alpha191", 0.10) +
                f8["score"] * self.w.get("frameworks", 0.10) +
                f9["score"] * self.w.get("consensus", 0.06) +
                f10["score"] * self.w.get("capital_flow", 0.06) +
                f11["score"] * self.w.get("market_signal", 0.06) +
                 f12["score"] * self.w.get("factorhub", 0.05) +
                 f13["score"] * self.w.get("event_factor", 0.00))
        return {"code": code, "total_score": round(total, 1),
                "factors": {"trend": f1, "volume": f2, "volatility": f3,
                           "capital": f4, "fundamental": f5, "sentiment": f6, 
                           "alpha191": f7, "frameworks": f8,
                           "consensus": f9, "capital_flow": f10, "market_signal": f11,
                            "factorhub": f12,
                            "event": f13}}

    def batch_score(self, codes: list) -> pd.DataFrame:
        rows = []
        for code in codes:
            try:
                r = self.score_stock(code)
                row = {"code": code, "total": r["total_score"]}
                for fn, fd in r["factors"].items():
                    if isinstance(fd, dict):
                        row[f"{fn}"] = fd.get("score", 0)
                    else:
                        row[f"{fn}"] = fd
                rows.append(row)
            except Exception as e:
                log.debug(f"跳过股票 {code}: {e}")
        df = pd.DataFrame(rows)
        if not df.empty: df.sort_values("total", ascending=False, inplace=True)
        return df
