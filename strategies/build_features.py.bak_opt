# ---- 因子阈值配置加载 ----
FACTOR_THRESHOLDS = CONFIG.get("factor_thresholds", {})


def score_by_boundaries(value, boundaries, scores, direction="gt"):
    """
    按边界阈值映射数值到分数
    direction="gt": value > boundary 取分 (高值高分)
    direction="lt": value < boundary 取分 (低值高分)
    """
    for i, b in enumerate(boundaries):
        is_last = (i == len(boundaries) - 1)
        if direction == "gt":
            if value >= b:
                return scores[i] if i < len(scores) else 0
        elif direction == "lt":
            if value <= b:
                return scores[i] if i < len(scores) else 0
    return 0



# ==================== 因子1: 趋势启动 ====================
def factor_trend(df: pd.DataFrame) -> Dict:
    """趋势启动因子 - 多周期排列+均线斜率+距新高距离"""
    if df.empty or len(df) < 60:
        return {"score": 0, "details": {}}
    T = FACTOR_THRESHOLDS.get("trend", {})
    c = df["收盘"].values
    s = 0; d = {}
    
    # 1. 多周期均线排列 (MA5>MA20>MA60 = 多头排列)
    ma5 = np.mean(c[-5:])
    ma20 = np.mean(c[-20:])
    ma60 = np.mean(c[-60:])
    bull = int(ma5 > ma20 > ma60)
    partial = int((ma5 > ma20) or (ma20 > ma60))
    s += bull * T.get("ma_bull_score", 25) + (partial - bull) * T.get("ma_partial_score", 10)
    d["ma_bull"] = bull; d["ma5"] = round(ma5, 2); d["ma20"] = round(ma20, 2); d["ma60"] = round(ma60, 2)
    
    # 2. 均线斜率 (20日均线上升角度)
    slope_20 = (ma20 - np.mean(c[-40:-20])) / np.mean(c[-40:-20])
    sl = T.get("slope", {"boundaries": [0.03, 0.01, 0], "scores": [15, 10, 5]})
    s += score_by_boundaries(slope_20, sl["boundaries"], sl["scores"])
    d["slope_20"] = round(slope_20*100, 2)
    
    # 3. 20日收益率
    ret_20 = c[-1] / c[-20] - 1
    r20 = T.get("ret20", {"boundaries": [0.20, 0.10, 0.05, 0.02, 0], "scores": [25, 20, 15, 10, 5]})
    s += score_by_boundaries(ret_20, r20["boundaries"], r20["scores"])
    d["ret_20"] = round(ret_20*100, 2)
    
    # 4. 60日收益率
    ret_60 = c[-1] / c[-60] - 1
    r60 = T.get("ret60", {"boundaries": [0.30, 0.15, 0.05, 0], "scores": [15, 12, 8, 4]})
    s += score_by_boundaries(ret_60, r60["boundaries"], r60["scores"])
    d["ret_60"] = round(ret_60*100, 2)
    
    # 5. 距120日新高距离
    high_120 = np.max(c[-120:]) if len(c) >= 120 else c[-1]
    dist = (c[-1] - high_120) / high_120
    dh = T.get("dist_from_high", {"boundaries": [0, -0.05, -0.10, -0.20], "scores": [20, 15, 10, 5]})
    s += score_by_boundaries(dist, dh["boundaries"], dh["scores"])
    d["dist_from_high"] = round(dist*100, 2); d["high_120"] = round(high_120, 2)
    
    return {"score": min(s, 100), "details": d}


# ==================== 因子2: 量能异动 ====================
def factor_volume(df: pd.DataFrame) -> Dict:
    """量能异动因子 - 放量等级+缩量回踩+连续价量配合"""
    if df.empty or len(df) < 20 or "成交量" not in df.columns:
        return {"score": 0, "details": {}}
    T = FACTOR_THRESHOLDS.get("volume", {})
    v = df["成交量"].values; c = df["收盘"].values
    v5 = np.mean(v[-5:]); v20 = np.mean(v[-20:])
    s = 0; d = {}
    
    # 1. 近5日放量等级 (相比20日均量)
    latest_v5 = v5 / v20 if v20 > 0 else 1
    vr = T.get("vol_ratio_5v20", {"boundaries": [2.0, 1.5, 1.2, 1.0], "scores": [25, 18, 12, 6]})
    s += score_by_boundaries(latest_v5, vr["boundaries"], vr["scores"])
    d["vol_ratio_5v20"] = round(latest_v5, 2)
    
    # 2. 单日放量 (最近3日最大放量倍数)
    last3_vr = [v[-i] / v5 if v5 > 0 else 1 for i in range(1, 4)]
    max_vr = max(last3_vr)
    ds = T.get("daily_spike", {"boundaries": [2.0, 1.5, 1.2], "scores": [15, 10, 5]})
    s += score_by_boundaries(max_vr, ds["boundaries"], ds["scores"])
    d["max_daily_vr"] = round(max_vr, 2)
    
    # 3. 换手率异动
    tu = df["换手率"].values if "换手率" in df.columns else v
    tr = np.mean(tu[-5:]) / np.mean(tu[-20:]) if np.mean(tu[-20:]) > 0 else 1
    tro = T.get("turnover_ratio", {"boundaries": [2.0, 1.5, 1.2], "scores": [15, 10, 5]})
    s += score_by_boundaries(tr, tro["boundaries"], tro["scores"])
    d["turn_ratio"] = round(tr, 2)
    
    # 4. 连续价量配合 (3日内放量上涨天数)
    cu = 0
    for i in range(1, min(4, len(v))):
        if v[-i] > v5 * 1.2 and c[-i] > (c[-i-1] if -i-1 >= -len(c) else c[-i]):
            cu += 1
    s += cu * 8
    d["consec_vol_up"] = cu
    
    # 5. 量价背离检测 (缩量回调)
    for i in range(min(15, len(v)-3)):
        if all(v[-i-j] < v5 * 0.8 for j in range(3) if -i-j >= -len(v)):
            if c[-1] > np.mean(c[-i-3:-i]) if -i-3 >= -len(c) else False:
                s += 25; d["pullback_rebound"] = 1; break
    else:
        d["pullback_rebound"] = 0
    
    return {"score": min(s, 100), "details": d}


# ==================== 因子3: 波动结构 ====================
def factor_volatility(df: pd.DataFrame) -> Dict:
    if df.empty or len(df) < 20:
        return {"score": 0, "details": {}}
    T = FACTOR_THRESHOLDS.get("volatility", {})
    hi = df["最高"].values if "最高" in df.columns else df["收盘"].values
    lo = df["最低"].values if "最低" in df.columns else df["收盘"].values
    cl = df["收盘"].values
    op = df["开盘"].values if "开盘" in df.columns else cl
    amp = (np.max(hi[-20:]) - np.min(lo[-20:])) / op[-20] if op[-20] != 0 else 0
    
    tr = np.zeros(len(cl))
    for i in range(1, len(cl)):
        tr[i] = max(hi[i]-lo[i], abs(hi[i]-cl[i-1]), abs(lo[i]-cl[i-1]))
    atr = np.mean(tr[-14:]) if len(tr) >= 14 else 0
    atr_p = np.mean(tr[-19:-14]) if len(tr) >= 19 else 0
    
    ad = len(tr) > 0 and len(tr) >= 26 and all(tr[-i] < np.mean(tr[-i-5:-i]) for i in range(1,6) if -i-5 >= -len(tr))
    ratio = T.get("atr_atr_p_ratio", 1.3)
    ae = atr > atr_p * ratio if atr_p > 0 else False
    
    s = 0
    amp_boundaries = T.get("amplitude", {"boundaries": [0.15, 0.10], "scores": [20, 10]})
    s += score_by_boundaries(amp, amp_boundaries["boundaries"], amp_boundaries["scores"])
    if ad and ae: s += T.get("squeeze_expand_score", 50)
    elif ae: s += T.get("atr_expand_only_score", 25)
    if atr > 0:
        max_pct = T.get("atr_max_pct", 30)
        s += min(atr / np.mean(cl[-20:]) * 1000, max_pct)
    return {"score": min(s, 100), "details": {
        "amp_20": round(amp*100, 2), "atr": round(atr, 2),
        "atr_expand": int(ae), "pattern": "squeeze_expand" if ad and ae else "normal"}}


# ==================== 因子4: 资金关注 ====================
def factor_capital(df: pd.DataFrame) -> Dict:
    """资金关注因子 - 成交额趋势+换手率热度+PE估值+相对强弱"""
    s = 0; d = {}
    if df.empty or len(df) < 20: return {"score": 0, "details": d}
    T = FACTOR_THRESHOLDS.get("capital", {})
    
    v = df["成交量"].values
    a = df["成交额"].values if "成交额" in df.columns else np.zeros(len(v))
    tr = df["换手率"].values if "换手率" in df.columns else np.ones(len(v))
    c = df["收盘"].values
    
    # 1. 成交额趋势 (5日 vs 20日)
    amt_5 = np.mean(a[-5:]); amt_20 = np.mean(a[-20:])
    amt_ratio = amt_5 / amt_20 if amt_20 > 0 else 1
    ar = T.get("amt_ratio", {"boundaries": [2.0, 1.5, 1.2, 0.8], "scores": [25, 18, 12, 6]})
    s += score_by_boundaries(amt_ratio, ar["boundaries"], ar["scores"])
    d["amt_ratio_5v20"] = round(amt_ratio, 2)
    
    # 2. 换手率趋势 (5日 vs 20日)
    tr_5 = np.mean(tr[-5:]); tr_20 = np.mean(tr[-20:])
    tr_ratio = tr_5 / tr_20 if tr_20 > 0 else 1
    tr_cfg = T.get("tr_ratio", {"boundaries": [2.0, 1.5, 1.2, 0.8], "scores": [20, 14, 8, 4]})
    s += score_by_boundaries(tr_ratio, tr_cfg["boundaries"], tr_cfg["scores"])
    d["tr_ratio_5v20"] = round(tr_ratio, 2)
    
    # 3. 成交额绝对额分档
    latest_amt = a[-1]
    al = T.get("amount_level", {"boundaries": [50e8, 20e8, 10e8, 5e8], "scores": [20, 15, 10, 5]})
    s += score_by_boundaries(latest_amt, al["boundaries"], al["scores"])
    d["amount_latest_100m"] = round(latest_amt / 1e8, 1)
    
    # 4. PE估值合理性 (direction=lt: 低PE高分)
    pe = df["市盈率"].dropna().values if "市盈率" in df.columns else np.array([np.nan])
    if len(pe) > 0 and not np.isnan(pe[-1]) and pe[-1] > 0:
        pe_latest = pe[-1]
        pe_cfg = T.get("pe_level", {"boundaries": [15, 25, 40, 60], "scores": [20, 15, 10, 5], "direction": "lt"})
        s += score_by_boundaries(pe_latest, pe_cfg["boundaries"], pe_cfg["scores"], direction=pe_cfg.get("direction", "gt"))
        d["pe"] = round(pe_latest, 1)
    
    # 5. 60日相对强度
    if len(c) >= 60:
        strength = (c[-1] / c[-60] - 1) * 100
        st = T.get("strength_60d", {"boundaries": [30, 15, 5, -5], "scores": [15, 10, 5, 3]})
        s += score_by_boundaries(strength, st["boundaries"], st["scores"])
        d["strength_60d"] = round(strength, 1)
    
    return {"score": min(s, 100), "details": d}


# ==================== 因子5: 基本面改善 ====================
def factor_fundamental(code: str, ol: "OptimizedDataLayer") -> Dict:
    s = 0; d = {}
    T = FACTOR_THRESHOLDS.get("fundamental", {})
    try:
        fin = ol.get_financial(code)
        if not fin.empty and "净资产收益率" in fin.columns:
            roe = fin["净资产收益率"].dropna()
            if not roe.empty:
                rl = float(roe.iloc[-1])
                rp = float(roe.iloc[-5]) if len(roe) >= 5 else rl
                roe_cfg = T.get("roe_level", {"boundaries": [15, 10, 5], "scores": [30, 20, 10]})
                s += score_by_boundaries(rl, roe_cfg["boundaries"], roe_cfg["scores"])
                if rl - rp > 0: s += T.get("roe_growth_score", 15)
                d["roe"] = round(rl, 1)
                if len(roe) >= 5: d["roe_change"] = round(rl-rp, 1)
        if "销售毛利率" in fin.columns:
            gm = fin["销售毛利率"].dropna()
            if not gm.empty:
                gl = float(gm.iloc[-1])
                gm_cfg = T.get("gross_margin", {"boundaries": [40, 20], "scores": [20, 10]})
                s += score_by_boundaries(gl, gm_cfg["boundaries"], gm_cfg["scores"])
                d["gross_margin"] = round(gl, 1)
        if "资产负债率" in fin.columns:
            dr = fin["资产负债率"].dropna()
            if not dr.empty:
                dl = float(dr.iloc[-1])
                dr_cfg = T.get("debt_ratio", {"boundaries": [30, 50], "scores": [15, 10], "direction": "lt"})
                s += score_by_boundaries(dl, dr_cfg["boundaries"], dr_cfg["scores"], direction=dr_cfg.get("direction", "gt"))
                d["debt_ratio"] = round(dl, 1)
    except Exception as e:
        log.debug(f"基本面数据获取失败: {e}")
    return {"score": min(s, 100), "details": d}



